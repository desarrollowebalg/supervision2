	<meta name="theme-color" content="#000000">
	<meta name="apple-mobile-web-app-capable" content="yes">
	<meta name="mobile-web-app-capable" content="yes">
	<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
	<meta name="apple-mobile-web-app-title" content="Movilizandome">
	<link rel="icon" type="image/vnd.microsoft.icon" href="{URL_FAVICON}" sizes="16x16 24x24 36x36 48x48">
	<link rel="manifest" href="/dist/manifest.webmanifest">
	<link rel="apple-touch-icon" href="/public/images/icons/icon-192x192.png">
